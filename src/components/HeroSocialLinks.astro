const items = Array.isArray(Astro.props.items) && Astro.props.items.length > 0 ? Astro.props.items : defaultItems;
---
<div class="hero-social-links" aria-label={isRu ? 'Социальные сети' : 'Social links'} data-hero-social-links>
  {items.map((item) => (
    <a
      class="hero-social-link"
      href={item.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={item.label}
      title={item.label}
      style={`--social-bg: ${item.bgColor || '#000000'}; --social-icon: ${item.iconColor || '#ffffff'}; --social-icon-size: ${(item.iconSize ?? 20)}px; --social-icon-scale: ${item.iconScale ?? 1}; --social-icon-offset-y: ${(item.iconOffsetY ?? 0)}px;`}
    >
      <svg viewBox={item.iconViewBox || '0 0 24 24'} aria-hidden="true">
        <path d={item.iconPath} />
      </svg>
    </a>
  ))}
</div>

<script is:inline>
  (() => {
    if (typeof document === 'undefined') return;
    const mount = () => {
      const socials = document.querySelector('[data-hero-social-links]');
      const actions = document.querySelector('.hero .actions');
      if (!socials || !actions) return;
      if (socials.parentElement !== actions.parentElement || socials.previousElementSibling !== actions) {
        actions.insertAdjacentElement('afterend', socials);
      }
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }
    document.addEventListener('astro:page-load', mount);
  })();
</script>

<style>
  .hero-social-links {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    margin-top: 0.45rem;
    margin-bottom: 0;
  }

  @media (max-width: 50rem) {
    .hero-social-links {
      justify-content: center;
    }
  }

  .hero-social-link {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--social-icon, #ffffff) !important;
    background: var(--social-bg, #000000);
    border: 1px solid var(--social-bg, #000000);
    transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease;
  }

  .hero-social-link:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  .hero-social-link:focus-visible {
    outline: 2px solid var(--ctp-mauve);
    outline-offset: 2px;
  }

  .hero-social-link svg {
    width: var(--social-icon-size, 20px);
    height: var(--social-icon-size, 20px);
    display: block;
    fill: var(--social-icon, #ffffff) !important;
    color: var(--social-icon, #ffffff) !important;
    transform: translateY(var(--social-icon-offset-y, 0px)) scale(var(--social-icon-scale, 1));
    transform-origin: 50% 50%;
  }

  .hero-social-link svg path {
    fill: var(--social-icon, #ffffff) !important;
  }
</style>
